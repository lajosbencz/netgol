# syntax=docker/dockerfile:1.7
# Dev image: vite dev server with HMR. Source is bind-mounted; node_modules
# stays inside the image so the host platform doesn't matter.
FROM node:22-alpine
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm ci --no-audit --no-fund
EXPOSE 5173
CMD ["npx", "vite", "--host", "0.0.0.0"]
