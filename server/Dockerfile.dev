# syntax=docker/dockerfile:1.7
# Dev image: cargo-watch + a registry/target volume mount makes incremental rebuilds fast.
FROM rust:1-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
 && rm -rf /var/lib/apt/lists/* \
 && cargo install cargo-watch --locked

WORKDIR /app
ENV NETGOL_CONFIG=/app/config/server.toml
ENV RUST_LOG=info
EXPOSE 8080 9090

# Source is bind-mounted; cargo-watch rebuilds on change. target-cpu=x86-64-v3
# is supplied by .cargo/config.toml for x86_64-linux targets.
CMD ["cargo", "watch", "-q", "-w", "simulation/src", "-w", "protocol/src", "-w", "server/src", "-x", "run -p server"]
